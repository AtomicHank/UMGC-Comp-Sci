    NEGOP (266) 62
    ANDOP (267) 49
    OROP (268) 47
    NOTOP (269) 51
    RELOP (270) 54
    ARROW (271) 31 38 39
    BEGIN_ (272) 20
    CASE (273) 38 39
    CHARACTER (274) 16
    ELSE (275) 32
    ELSIF (276) 34
    END (277) 20
    ENDIF (278) 32
    ENDFOLD (279) 33
    ENDSWITCH (280) 31
    FOLD (281) 33
    FUNCTION (282) 2 3
    IF (283) 32
    INTEGER (284) 14
    IS (285) 11 12 13 31
    LEFT (286) 40
    LIST (287) 12
    OF (288) 12
    OTHERS (289) 31
    REAL (290) 15
    RETURNS (291) 2
    RIGHT (292) 41
    SWITCH (293) 31
    THEN (294) 32 34
    WHEN (295) 24 25 26 27 28 29 30


