    EXPOP <oper> (265) 37 54
    NEGOP <oper> (266) 56
    ANDOP <oper> (267) 43
    OROP <oper> (268) 41
    NOTOP <oper> (269) 45
    RELOP <oper> (270) 48
    ARROW (271) 24 31
    BEGIN_ (272) 18
    CASE (273) 31
    CHARACTER (274) 14
    ELSE (275) 25
    ELSIF (276) 27
    END (277) 18
    ENDIF (278) 25
    ENDFOLD (279) 26
    ENDSWITCH (280) 24
    FOLD (281) 26
    FUNCTION (282) 2
    IF (283) 25
    INTEGER (284) 12
    IS (285) 10 11 24
    LEFT (286) 32
    LIST (287) 11
    OF (288) 11
    OTHERS (289) 24
    REAL (290) 13
    RETURNS (291) 2
    RIGHT (292) 33
    SWITCH (293) 24
    THEN (294) 25 27
    WHEN (295) 22


