        on right: 8
    type <type> (54)
        on left: 12 13 14
        on right: 2 7 10 11
    list <type> (55)
        on left: 15
        on right: 11 35
    expressions <type> (56)
        on left: 16 17
        on right: 15 16
    body <type> (57)
        on left: 18
        on right: 1
    statement_ <type> (58)
        on left: 19 20
        on right: 10 18 23 24 26 30
    statement <type> (59)
        on left: 21 22 23 24 25
        on right: 19
    elsif_clauses <type> (60)
        on left: 26 27
        on right: 24 26
    cases <type> (61)
        on left: 28 29
        on right: 23 28
    case <type> (62)
        on left: 30
        on right: 28
    direction <type> (63)
        on left: 31 32
        on right: 25
    operator <type> (64)
        on left: 33 34
        on right: 25
    list_choice <type> (65)
        on left: 35 36
        on right: 25
    condition <type> (66)
        on left: 37
        on right: 22 24 26 44
    or_condition <type> (67)
        on left: 38 39
        on right: 37 38
    and_condition <type> (68)
        on left: 40 41
        on right: 38 39 40
    not_condition <type> (69)
        on left: 42 43
        on right: 40 41 42
    relation <type> (70)
        on left: 44 45
        on right: 43
    expression <type> (71)
        on left: 46 47
        on right: 16 17 21 22 23 45 46 55 59
    term <type> (72)
        on left: 48 49 50
        on right: 46 47 48 49
    power <type> (73)
        on left: 51 52
        on right: 48 49 50 51
    unary <type> (74)
        on left: 53 54
        on right: 51 52 53
    primary <type> (75)
        on left: 55 56 57 58 59 60
        on right: 54


State 0

    0 $accept: . function $end

    FUNCTION  shift, and go to state 1

    function         go to state 2
    function_header  go to state 3


State 1

    2 function_header: FUNCTION . IDENTIFIER optional_parameters RETURNS type ';'

    IDENTIFIER  shift, and go to state 4


